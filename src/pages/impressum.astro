---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import { site } from "../config/site";
---
<BaseLayout title={`${site.bandName} — Impressum`}>
  <Nav />
  <main class="section">
    <div class="container">
      <div class="kicker"><div class="dot"></div><div class="small">Legals</div></div>
      <h1 class="h2" style="font-size: clamp(34px, 4vw, 54px); margin-top: 10px;">Impressum</h1>

      <div class="card" style="padding:18px; margin-top:18px;">
        <div class="small">Angaben gemäß § 5 DDG</div>
        <p class="p" style="margin-top:10px;">
          Anbieter: FIVEHEADS<br />
          Verantwortlich: Alexander Nowak<br />
          Anschrift: Klarastrasse 8, 80636 München, Deutschland
        </p>

        <div class="hr"></div>

        <div class="small">Kontakt</div>
        <p class="p" style="margin-top:10px;">
          E-Mail: <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a><br />
          Telefon: <a href="tel:+491624075426">+49 162 4075426</a>
        </p>

        <div class="hr"></div>

        <div class="small">Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</div>
        <p class="p" style="margin-top:10px;">
          Alexander Nowak<br />
          Klarastrasse 8, 80636 München, Deutschland
        </p>

        <div class="hr"></div>

        <div class="small">Bildnachweis</div>
        <p class="p" style="margin-top:10px;">
          Die auf dieser Website verwendeten Live-Fotos stammen von Bernd Satzinger.<br />
          Instagram: <a href="https://www.instagram.com/satzingb?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener">instagram.com/satzingb</a>
        </p>
      </div>
    </div>
  </main>
</BaseLayout>
