---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import { site } from "../config/site";

const gallery = import.meta.glob("../assets/gallery/*.{jpg,jpeg,png,webp,avif}", { eager: true });
const imgs = Object.values(gallery).map((m) => m.default).filter(Boolean);
imgs.sort((a, b) => (b.src || "").localeCompare(a.src || ""));
---
<BaseLayout title={`${site.bandName} — Gallery`}>
  <Nav />

  <main class="section">
    <div class="container">
      <h1 class="h2" style="font-size: clamp(34px, 4vw, 54px); margin-top: 10px;">Unsere letzten Shows</h1>

      <div class="hr"></div>

      {imgs.length ? (
        <>
          <div class="photoGrid" id="grid">
            {imgs.map((img) => (
              <button class="photoItem" type="button" data-full={img.src} aria-label="Foto öffnen">
                <img src={img.src} alt="Live Foto" loading="lazy" />
              </button>
            ))}
          </div>

          <dialog class="modal" id="modal">
            <div class="inner">
              <header>
                <div class="small">Live Foto</div>
                <button type="button" id="close">Schließen</button>
              </header>
              <img id="modalImg" src="" alt="Live Foto groß" />
            </div>
          </dialog>

          <script is:inline>
            var grid = document.getElementById("grid");
            var modal = document.getElementById("modal");
            var modalImg = document.getElementById("modalImg");
            var closeBtn = document.getElementById("close");

            function setModalOpen(isOpen) {
              if (!modal) return;
              if (isOpen) {
                modal.classList.add("is-open");
                modal.setAttribute("open", "");
                if (typeof modal.showModal === "function" && !modal.open) {
                  try { modal.showModal(); } catch (_) {}
                }
                document.body.style.overflow = "hidden";
                return;
              }

              modal.classList.remove("is-open");
              if (typeof modal.close === "function" && modal.open) {
                try { modal.close(); } catch (_) {}
              }
              modal.removeAttribute("open");
              document.body.style.overflow = "";
            }

            function openModal(src){
              if (!modalImg || !src) return;
              modalImg.src = src;
              setModalOpen(true);
            }

            function closeModal(){
              setModalOpen(false);
              if (modalImg) modalImg.src = "";
            }

            if (grid) {
              grid.addEventListener("click", function (e) {
                var target = e.target;
                if (!(target instanceof Element)) return;
                var btn = target.closest("button[data-full]");
                if (!btn) return;
                var src = btn.getAttribute("data-full");
                if (src) openModal(src);
              });
            }

            if (closeBtn) closeBtn.addEventListener("click", closeModal);
            if (modal) {
              modal.addEventListener("click", function (e) {
                if (e.target === modal) closeModal();
              });
            }
            window.addEventListener("keydown", function (e) {
              if (e.key === "Escape") closeModal();
            });
          </script>
        </>
      ) : (
        <div class="card" style="padding:18px;">
          <div class="small">Noch keine Bilder gefunden</div>
          <p class="p" style="margin-top:10px;">
            Lege Fotos in <code>src/assets/gallery/</code> ab.
          </p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>
