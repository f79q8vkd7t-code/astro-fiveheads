---
import { site } from "../config/site";
const items = [
  { href: "/#about", label: "About" },
  { href: "/#live", label: "Live" },
  { href: "/#music", label: "Music" },
  { href: "/gallery", label: "Gallery" },
  { href: "/#contact", label: "Contact" }
];
---
<nav class="nav" id="topnav">
  <div class="container row">
    <a class="logo" href="/">{site.bandName}</a>
    <button
      type="button"
      class="navToggle"
      id="navToggle"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="navLinks"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="links" id="navLinks">
      {items.map((i) => (
        <a href={i.href}>{i.label}</a>
      ))}
      <a href={site.links.instagram} target="_blank" rel="noopener">Instagram</a>
      <a href={site.links.tiktok} target="_blank" rel="noopener">TikTok</a>
    </div>
  </div>

  <script is:inline>
    (function(){
      function initNav() {
        const nav = document.getElementById("topnav");
        const toggle = document.getElementById("navToggle");
        const links = document.getElementById("navLinks");
        if (!nav) return;

        const previousCleanup = window.__fiveheadsNavCleanup;
        if (typeof previousCleanup === "function") previousCleanup();
        const cleanups = [];
        const on = (target, type, handler, options) => {
          target.addEventListener(type, handler, options);
          cleanups.push(() => target.removeEventListener(type, handler, options));
        };

        const onScroll = () => {
          if (window.scrollY > 10) nav.classList.add("scrolled");
          else nav.classList.remove("scrolled");
        };
        const setExpanded = (isOpen) => {
          if (!toggle) return;
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
          toggle.setAttribute("aria-label", isOpen ? "Menü schließen" : "Menü öffnen");
        };
        const closeMenu = () => {
          nav.classList.remove("open");
          setExpanded(false);
        };
        const toggleMenu = () => {
          const willOpen = !nav.classList.contains("open");
          nav.classList.toggle("open", willOpen);
          setExpanded(willOpen);
        };

        onScroll();
        on(window, "scroll", onScroll, { passive: true });

        if (toggle) {
          on(toggle, "click", toggleMenu);
        }

        if (links) {
          on(links, "click", (e) => {
            const target = e.target;
            if (!(target instanceof Element)) return;
            if (target.closest("a")) closeMenu();
          });
        }

        on(window, "resize", () => {
          if (window.innerWidth > 900) closeMenu();
        });
        on(window, "keydown", (e) => {
          if (e.key === "Escape") closeMenu();
        });
        on(document, "click", (e) => {
          const target = e.target;
          if (!(target instanceof Element)) return;
          if (!nav.contains(target)) closeMenu();
        });

        window.__fiveheadsNavCleanup = () => {
          for (const cleanup of cleanups) cleanup();
        };
      }

      initNav();
      document.addEventListener("astro:page-load", initNav);
    })();
  </script>
</nav>
