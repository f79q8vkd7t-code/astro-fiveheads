---
const { compact = false } = Astro.props;
---
<div class:list={["musicPlayerWrap", compact && "musicPlayerCompact"]}>
  <audio
    id="band-audio"
    transition:name="band-audio"
    transition:persist
    controls
    preload="metadata"
    style="width:100%;"
  >
    <source src="/audio/song.mp3" type="audio/mpeg" />
    <source src="/audio/song.wav" type="audio/wav" />
    Dein Browser unterstützt den Audio-Player nicht.
  </audio>
</div>
