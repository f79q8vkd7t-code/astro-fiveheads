---
import { shows } from "../data/shows";

const fmt = (iso) => {
  const d = new Date(iso + "T00:00:00");
  return new Intl.DateTimeFormat("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" }).format(d);
};

const sorted = [...shows].sort((a, b) => a.date.localeCompare(b.date));
---
<div class="card" style="padding:18px;">
  <div class="small" style="margin-bottom:10px;">Next shows</div>

  {sorted.length ? (
    <div class="showListRows">
      {sorted.map((s) => (
        <div class="showRow">
          <div class="small showDate">{fmt(s.date)}</div>

          <div class="showMain">
            <div class="showTitle">{s.city} — {s.venue}</div>
            <div class="small" style="margin-top:4px; opacity:.8;">
              {s.note ? s.note : ""}{s.country ? (s.note ? " · " : "") + s.country : ""}
            </div>
          </div>

          {s.ticketUrl ? (
            <a class="btn showAction" href={s.ticketUrl} target="_blank" rel="noopener">Info</a>
          ) : (
            <span class="small showAction">Info</span>
          )}
        </div>
      ))}
    </div>
  ) : (
    <div class="showEmpty">
      <div class="showTitle">Aktuell keine neuen Termine</div>
      <div class="small" style="margin-top:6px; opacity:.8;">Neue Shows werden hier bekanntgegeben.</div>
    </div>
  )}
</div>

<style>
  .showListRows{
    display:grid;
    gap:10px;
  }

  .showRow{
    display:grid;
    grid-template-columns: minmax(88px, 110px) minmax(0, 1fr) auto;
    gap:12px;
    align-items:center;
    border-top:1px solid var(--line);
    padding-top:10px;
  }

  .showDate{
    letter-spacing:.18em;
    color:var(--fg);
    opacity:.9;
  }

  .showMain{
    min-width:0;
  }

  .showTitle{
    font-weight:700;
    letter-spacing:-.01em;
    overflow-wrap:anywhere;
  }

  .showAction{
    white-space:nowrap;
  }

  .showEmpty{
    border-top:1px solid var(--line);
    padding-top:12px;
  }

  @media (max-width: 640px){
    .showRow{
      grid-template-columns: minmax(0, 1fr) auto;
      gap:6px 10px;
    }

    .showDate{
      grid-column: 1 / -1;
    }

    .showMain{
      grid-column: 1;
    }

    .showAction{
      grid-column: 2;
      align-self: start;
      justify-self:end;
    }
  }
</style>
